DISCORD_TOKEN=your_bot_token_here
MODMAIL_FORUM_ID=your_forum_channel_id_here
MOD_LOG_CHANNEL_ID=your_log_channel_id_here

# Optional Railway channel variables. Leave blank to use the fallback behavior.
# SERVER_STATS_CHANNEL_ID is a dedicated channel the bot can rename with live stats like members-1234.
# SERVER_STATS_CHANNEL_FORMAT supports {guild}, {online}, {total}, and {boosters}.
# The channel IDs below let the bot rename separate stat channels like your screenshot:
# all-members-823, members-800, bots-23, boosts-4, online-members-107
# SERVER_LOG_CHANNEL_ID falls back to MOD_LOG_CHANNEL_ID.
# INVITE_LOG_CHANNEL_ID falls back to SERVER_LOG_CHANNEL_ID, then MOD_LOG_CHANNEL_ID.
# VERIFICATION_LOG_CHANNEL_ID falls back to SERVER_LOG_CHANNEL_ID, then MOD_LOG_CHANNEL_ID.
SERVER_STATS_CHANNEL_ID=your_server_stats_channel_id_here
SERVER_STATS_CHANNEL_FORMAT=members-{total}
ALL_MEMBERS_STATS_CHANNEL_ID=your_all_members_channel_id_here
MEMBERS_STATS_CHANNEL_ID=your_members_channel_id_here
BOTS_STATS_CHANNEL_ID=your_bots_channel_id_here
BOOSTS_STATS_CHANNEL_ID=your_boosts_channel_id_here
ONLINE_MEMBERS_STATS_CHANNEL_ID=your_online_members_channel_id_here
SERVER_LOG_CHANNEL_ID=your_server_log_channel_id_here
INVITE_LOG_CHANNEL_ID=your_invite_log_channel_id_here
VERIFICATION_LOG_CHANNEL_ID=your_verification_log_channel_id_here
WELCOME_CHANNEL_ID=your_welcome_channel_id_here
# Optional private channel where the bot mirrors uploaded NE Coins and shop item images.
ASSET_CHANNEL_ID=your_asset_channel_id_here
# Optional ticket locations. If TICKET_CATEGORY_ID is blank, the bot uses or creates a category named Tickets.
# TICKET_TRANSCRIPT_CHANNEL_ID is the fallback until an admin runs /ticket setlog.
# If both are unset, transcripts fall back to MOD_LOG_CHANNEL_ID.
TICKET_CATEGORY_ID=your_ticket_category_id_here
TICKET_TRANSCRIPT_CHANNEL_ID=your_ticket_transcript_channel_id_here

STAFF_APPLICATION_CHANNEL_ID=your_staff_application_review_channel_id_here
MODERATOR_ROLE_ID=your_moderator_role_id_here
ADMIN_ROLE_ID=your_admin_role_id_here
VERIFIED_ROLE_ID=your_verified_role_id_here
# Optional PostgreSQL connection string for persistent storage.
# Required for /suggestionpanel and NE Coins/shop persistence.
DATABASE_URL=postgresql://username:password@host:5432/database

ANTI_RAID_ENABLED=true
ANTI_RAID_JOIN_THRESHOLD=5
ANTI_RAID_WINDOW_SECONDS=20
ANTI_RAID_LOCKDOWN_MINUTES=10
ANTI_RAID_ACCOUNT_AGE_MINUTES=30
ANTI_RAID_TIMEOUT_MINUTES=30
BOT_STATUS_TEXT=Guardian of Northeast Esports
